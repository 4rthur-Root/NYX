# {{ ansible_managed }}
# Loopback
auto lo
iface lo inet loopback

# Interface de Management Vagrant
auto eth0
iface eth0 inet dhcp
    # S'assurer que cette interface ne devient pas la route par défaut
    post-up ip route del default dev eth0 || true

# Interface LAN — réseau nyx (10.0.1.0/24)
auto eth1
iface eth1 inet static
    address {{ ip_address }}
    netmask {{ netmask }}
    gateway {{ gateway }}
    dns-nameservers {{ dns_servers | join(' ') }}
    # Force la route par défaut via OPNsense — eth0 (Vagrant) reste pour OOB management
    post-up ip route replace default via {{ gateway }} dev eth1
