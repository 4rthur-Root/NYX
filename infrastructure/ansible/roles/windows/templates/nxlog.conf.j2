## Géré par Ansible
define ROOT C:\ProgramData\NXLog

LogRoot %ROOT%
LogFile nxlog.log

<Extension syslog>
    Module      xm_syslog
</Extension>

<Input sysmon>
    Module      im_msvistalog
    Query       <QueryList><Query Id="0"><Select Path="Microsoft-Windows-Sysmon/Operational">*</Select></Query></QueryList>
</Input>

<Output out>
    Module      om_udp
    Host        {{ nxlog_server }}
    Port        {{ nxlog_port }}
    OutputType  Syslog
</Output>

<Route 1>
    Path        sysmon => out
</Route>
