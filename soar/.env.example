# AbuseIPDB (Étape 6)
ABUSEIPDB_API_KEY=your_api_key_here

# OPNsense (Étape 7)
OPNSENSE_API_URL=https://opnsense.internal/api
OPNSENSE_API_KEY=your_key_here
OPNSENSE_API_SECRET=your_secret_here
OPNSENSE_VERIFY_SSL=false   # certificat auto-signé en lab

# Notifications Telegram (Étape 13)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Notifications Email (Étape 13, optionnel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_TO=admin@example.com

# Général
LOG_LEVEL=INFO
