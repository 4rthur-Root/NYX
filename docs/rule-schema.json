{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NyxSOC Detection Rule",
  "description": "Schéma de validation des règles de détection YAML du moteur NyxSOC. Toute règle doit être conforme à ce schéma avant d'être chargée par le RuleEngine.",
  "version": "1.1.0",

  "definitions": {

    "severity": {
      "type": "string",
      "enum": ["WARNING", "CRITICAL"]
    },

    "event_type": {
      "type": "string",
      "enum": [
        "ssh_failure", "logon_success", "logon_failure",
        "samba_read", "samba_write", "smb_failure",
        "http_request", "net_scan", "firewall_block",
        "file_create", "process_exec", "net_connect"
      ],
      "description": "samba_write : création ou modification d'un fichier sur partage Samba. Déclenche YARA systématiquement dans le Dispatcher."
    },

    "mitre_tactic":    { "type": "string", "pattern": "^TA[0-9]{4}$" },
    "mitre_technique": { "type": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$" },
    "source_host_pattern": { "type": "string" },

    "response": {
      "type": "object",
      "required": ["alert"],
      "properties": {
        "alert": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "trigger_type1": {
      "type": "object",
      "required": ["event_type", "threshold", "window_seconds", "group_by"],
      "properties": {
        "event_type":      { "$ref": "#/definitions/event_type" },
        "threshold":       { "type": "integer", "minimum": 1 },
        "window_seconds":  { "type": "integer", "minimum": 1 },
        "group_by":        { "type": "string", "enum": ["actor_ip", "actor_user", "source_host"] },
        "filter": {
          "type": "object",
          "properties": {
            "http_status": { "type": "array", "items": { "type": "integer" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "step_type2": {
      "type": "object",
      "required": ["step", "event_type"],
      "properties": {
        "step":                  { "type": "integer", "minimum": 1 },
        "event_type":            { "$ref": "#/definitions/event_type" },
        "source_host_pattern":   { "$ref": "#/definitions/source_host_pattern" },
        "window_seconds":        { "type": "integer", "minimum": 1 },
        "match_on":              { "type": "string", "enum": ["actor_ip", "actor_user", "source_host"] },
        "condition": {
          "type": "object",
          "properties": {
            "yara_match": {
              "type": "string",
              "enum": ["required", "optional", "none"],
              "description": "required : step validé seulement si yara_match != null dans l'événement stocké."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "condition_type3": {
      "type": "object",
      "required": ["event_types", "window_seconds", "group_by"],
      "properties": {
        "event_types":        { "type": "array", "minItems": 2, "items": { "$ref": "#/definitions/event_type" } },
        "window_seconds":     { "type": "integer", "minimum": 1 },
        "group_by":           { "type": "string", "enum": ["actor_ip", "actor_user"] },
        "min_count_per_type": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "additionalProperties": false
    },

    "trigger_type4": {
      "type": "object",
      "required": ["event_type", "yara_match"],
      "properties": {
        "event_type": {
          "type": "string",
          "enum": ["samba_write"],
          "description": "Type 4 est exclusivement déclenché sur samba_write. YARA tourne sur tous les samba_write dans le Dispatcher — cette règle filtre ceux où il y a eu un match."
        },
        "yara_match":          { "type": "string", "enum": ["required"] },
        "source_host_pattern": { "$ref": "#/definitions/source_host_pattern" }
      },
      "additionalProperties": false
    }
  },

  "type": "object",
  "required": ["rule_id", "type", "description", "severity", "mitre_tactic", "mitre_technique", "response"],

  "properties": {
    "rule_id":             { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+_[0-9]{3}$" },
    "type":                { "type": "integer", "enum": [1, 2, 3, 4] },
    "description":         { "type": "string" },
    "severity":            { "$ref": "#/definitions/severity" },
    "mitre_tactic":        { "$ref": "#/definitions/mitre_tactic" },
    "mitre_technique":     { "$ref": "#/definitions/mitre_technique" },
    "source_host_pattern": { "$ref": "#/definitions/source_host_pattern" },
    "trigger":             { "$ref": "#/definitions/trigger_type1" },
    "steps":               { "type": "array", "minItems": 2, "items": { "$ref": "#/definitions/step_type2" } },
    "condition":           { "$ref": "#/definitions/condition_type3" },
    "yara_trigger":        { "$ref": "#/definitions/trigger_type4" },
    "response":            { "$ref": "#/definitions/response" }
  },

  "allOf": [
    { "if": { "properties": { "type": { "const": 1 } } }, "then": { "required": ["trigger"] } },
    { "if": { "properties": { "type": { "const": 2 } } }, "then": { "required": ["steps"] } },
    { "if": { "properties": { "type": { "const": 3 } } }, "then": { "required": ["condition"] } },
    { "if": { "properties": { "type": { "const": 4 } } }, "then": { "required": ["yara_trigger"] } }
  ],

  "additionalProperties": false
}